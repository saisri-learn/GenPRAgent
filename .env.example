# GitHub Configuration (Required)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# AI Model API Keys
# Anthropic (Claude) - for best quality
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT) - for testing/cost optimization
OPENAI_API_KEY=sk-your-openai-key-here

# Application Configuration
HOST=0.0.0.0
PORT=8000

# Model Configuration
# Any LangChain-compatible model name. Examples:
#   claude-sonnet-4-6  (Anthropic - best quality)
#   claude-haiku-4-5-20251001  (Anthropic - fast/cheap)
#   gpt-4o-mini  (OpenAI - fast/cheap)
#   gpt-4o  (OpenAI - capable)
#   auto  (HybridPRAgent only - selects based on complexity)
MODEL=claude-sonnet-4-6
